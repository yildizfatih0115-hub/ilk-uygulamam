<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Başlık -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FF4444"
                android:contentDescription="Geri"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚙ JARVIS AYARLARI"
                android:textColor="#FF4444"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <!-- API Anahtarı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#100505"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🤖 GEMINI API ANAHTARI"
                    android:textColor="#FF4444"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="AIza... (API anahtarını buraya yapıştır)"
                    android:textColor="#FFCCCC"
                    android:textColorHint="#664444"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:inputType="textPassword"
                    android:layout_marginTop="8dp"/>
                <Button
                    android:id="@+id/btnGetApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="🌐 Google AI Studio'dan ücretsiz al"
                    android:textSize="11sp"
                    android:textColor="#FF8888"
                    android:backgroundTint="#200A0A"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- JARVIS adı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#100505"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ASISTAN ADI"
                    android:textColor="#FF4444"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>
                <EditText
                    android:id="@+id/etJarvisName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="JARVIS"
                    android:textColor="#FFCCCC"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Switch'ler -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#100505"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Hotword -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎤 Hotword Aktif"
                        android:textColor="#FFCCCC"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <Switch
                        android:id="@+id/switchHotword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FF4444"
                        android:trackTint="#661111"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#331111" android:layout_marginVertical="8dp"/>

                <!-- TTS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔊 Sesli Yanıt (TTS)"
                        android:textColor="#FFCCCC"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <Switch
                        android:id="@+id/switchTts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FF4444"
                        android:trackTint="#661111"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#331111" android:layout_marginVertical="8dp"/>

                <!-- Auto Start -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🚀 Açılışta Başlat"
                        android:textColor="#FFCCCC"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <Switch
                        android:id="@+id/switchAutoStart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FF4444"
                        android:trackTint="#661111"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#331111" android:layout_marginVertical="8dp"/>

                <!-- Game Mode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎮 Oyun Modu"
                        android:textColor="#FFCCCC"
                        android:textSize="13sp"
                        android:fontFamily="monospace"/>
                    <Switch
                        android:id="@+id/switchGameMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FF4444"
                        android:trackTint="#661111"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Kaydet butonu -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="✅ KAYDET"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:backgroundTint="#CC2200"
            android:layout_marginTop="20dp"/>

        <View android:layout_width="match_parent" android:layout_height="24dp"/>
    </LinearLayout>
</ScrollView>
