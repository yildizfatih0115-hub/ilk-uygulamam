<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Başlık -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#44FF44"
                android:contentDescription="Geri"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡ GIBBERLINK PROTOKOLÜ"
                android:textColor="#44FF44"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Protokol bilgisi -->
        <TextView
            android:id="@+id/tvProtocol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Protokol: FSK Bell-202 | 300 baud | XOR-256"
            android:textColor="#88FF44"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

        <!-- Dalga görselleştirme placeholder -->
        <View
            android:id="@+id/waveView"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#111111"
            android:layout_marginTop="12dp"/>

        <TextView
            android:id="@+id/tvWavePhase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0.00 rad"
            android:textColor="#44FF44"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:gravity="center"/>

        <!-- Oturum anahtarı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0A1A0A"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvSessionKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Oturum Anahtarı: ..."
                    android:textColor="#44FF44"
                    android:textSize="11sp"
                    android:fontFamily="monospace"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnNewKey"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="🔑 Yeni Anahtar"
                        android:textSize="11sp"
                        android:textColor="#44FF44"
                        android:backgroundTint="#1A2A1A"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnShareKey"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="📋 Anahtarı Göster"
                        android:textSize="11sp"
                        android:textColor="#44FF44"
                        android:backgroundTint="#1A2A1A"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- GÖNDERİCİ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0A0A1A"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📡 GÖNDERİCİ"
                    android:textColor="#4444FF"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Şifreli mesaj gir..."
                    android:textColor="#CCCCFF"
                    android:textColorHint="#555577"
                    android:background="@drawable/bg_input"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:inputType="text"/>

                <ProgressBar
                    android:id="@+id/progressTx"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:progressTint="#4444FF"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvTxStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hazır"
                    android:textColor="#8888CC"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>

                <Button
                    android:id="@+id/btnSend"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="📡 GÖNDER (FSK)"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#222266"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ALICI -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#0A1A0A"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎙 ALICI"
                    android:textColor="#44FF44"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvSignalLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sinyal: 0"
                    android:textColor="#88FF44"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>

                <ProgressBar
                    android:id="@+id/signalBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progressTint="#44FF44"
                    android:max="100"/>

                <TextView
                    android:id="@+id/tvRxStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hazır"
                    android:textColor="#88AA88"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvReceived"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="(henüz mesaj alınmadı)"
                    android:textColor="#44FF44"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:background="#0D220D"
                    android:layout_marginTop="8dp"
                    android:minHeight="40dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/btnReceive"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="🎙 Dinle"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#226622"
                        android:layout_marginEnd="4dp"/>

                    <Button
                        android:id="@+id/btnSelfTest"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="🧪 Test"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#224422"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- LOG -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#080808"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 SİSTEM LOGU"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#55FF55"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View android:layout_width="match_parent" android:layout_height="24dp"/>

    </LinearLayout>
</ScrollView>
